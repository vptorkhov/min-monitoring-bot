# Telegram Bot Token
BOT_TOKEN=string

# Режим получения апдейтов от Telegram: polling или webhook
BOT_UPDATE_MODE=polling

# Webhook настройки (обязательны только если BOT_UPDATE_MODE=webhook)
WEBHOOK_BASE_URL=https://your-app-name.example.com
WEBHOOK_PATH=/webhook/telegram
WEBHOOK_SECRET_TOKEN=change_me

# Опционально: удалить webhook при graceful shutdown (true/false)
WEBHOOK_DELETE_ON_SHUTDOWN=false

# Порт сервера
PORT=3000

# Database configuration
DB_HOST=string
DB_PORT=string
DB_NAME=string
DB_USER=string
DB_PASSWORD=string